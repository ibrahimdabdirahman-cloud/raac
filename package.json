{
  "name": "raac",
  "version": "1.0.0",
  "description": "Raac — ride hailing for the Somali world (web + iOS + Android)",
  "scripts": {
    "build:mobile": "node tools/build-mobile.mjs",
    "sync": "node tools/build-mobile.mjs && cap sync",
    "ios": "node tools/build-mobile.mjs && cap sync ios && cap open ios",
    "android": "node tools/build-mobile.mjs && cap sync android && cap open android",
    "assets": "capacitor-assets generate --assetPath resources --iconBackgroundColor \"#070b12\" --iconBackgroundColorDark \"#070b12\" --splashBackgroundColor \"#070b12\" --splashBackgroundColorDark \"#070b12\""
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.1"
  },
  "private": true
}
